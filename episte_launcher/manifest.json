{
  "manifest_version": 3,
  "name": "episte-launcher",
  "version": "1.0",
  "description": "Launcher rápido para recursos LOVE y Epistemonikos",
  "icons": {
    "16": "episte_launcher.png",
    "48": "episte_launcher.png",
    "128": "episte_launcher.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Abrir episte-launcher",
    "default_icon": "episte_launcher.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabs"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "Command+Shift+Space"
      },
      "description": "Abre el menú de episte-launcher"
    }
  }
}
